node_modules/
main.js
styles.css
styles/app.scoped.generated.css
.tmp/
.DS_Store
scripts/logs/

# Track the vendored vin stylesheet — the `styles.css` line above is meant to
# ignore the bundled output at the repo root, but it also matches this source
# file. Without this allow-rule a clean checkout would lose the .vin-terminal-*
# rules and esbuild would silently emit a `/* missing */` placeholder.
!src/vendor/workdesk-terminal/styles.css

# When the repo is symlinked as a plugin folder into a vault, Obsidian writes
# the plugin's runtime settings to data.json at the repo root. Operator-private,
# never committed.
data.json

# Generated at runtime by writePtyHelper() — the PTY helper script is
# materialized next to the plugin folder when the repo is symlinked as a
# plugin into a vault. Not a tracked source artifact.
pty-helper.py

# Per-developer AI-assist tooling (Claude Code skills, slash commands). The
# obsidian-plugin skill is documented in
# `~/Workdesk-OS/intel/research/obsidian-plugin-development.md` §9 — contributors
# install it globally at `~/.claude/skills/obsidian-plugin/` rather than per-repo.
.claude/
